# APS Application credentials
# Register your app at https://aps.autodesk.com/myapps
APS_CLIENT_ID=
APS_CLIENT_SECRET=
APS_CALLBACK_URL=http://localhost:3000/auth/callback

# Local server port — used for OAuth callback and Autodesk Viewer
PORT=3000

# FORMA GraphQL endpoint
# Confirm exact URL from https://developer.autodesk.com (search "FORMA GraphQL")
FORMA_GRAPHQL_URL=https://developer.api.autodesk.com/forma/v1alpha/graphql
